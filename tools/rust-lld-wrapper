#!/usr/bin/env python3

# A wrapper for rust-lld that removes certain arguments inserted by rustc that
# we'd like to override

import sys
import subprocess
import re
from os import path

def main():
    args = sys.argv[1:]

    strip_debug = "--v86-strip-debug" in args

    # filter out args inserted by rustc
    TO_REMOVE = {
        "--export-table",
        "--stack-first",
        "--strip-debug",
        "--v86-strip-debug",
    }
    args = filter_linker_args(args, TO_REMOVE)
    if "--no-stack-first" not in args:
        args += ["--no-stack-first"]

    if strip_debug:
        args += ["--strip-debug"]

    lld = find_rust_lld()

    result = subprocess.run([lld] + args, stdout=subprocess.PIPE, stderr=subprocess.PIPE)

    if result.stderr:
        print(result.stderr.decode("utf8", errors="replace"), file=sys.stderr, end="")
    if result.stdout:
        print(result.stdout.decode("utf8", errors="replace"), end="")

    result.check_returncode()

def filter_linker_args(args, to_remove):
    result = []
    skip_next = False

    for i, arg in enumerate(args):
        if skip_next:
            skip_next = False
            continue

        if arg in to_remove:
            continue

        # Newer rustc/rust-lld can pass wasm linker options in "-z value" form.
        # Keep overriding rustc's stack placement, regardless of spelling.
        if arg == "-z" and i + 1 < len(args) and args[i + 1] == "stack-first":
            skip_next = True
            continue

        if arg == "-zstack-first":
            continue

        result.append(arg)

    return result

def find_host_triplet():
    rustc = subprocess.run(["rustc", "--version", "--verbose"], stdout=subprocess.PIPE, stderr=subprocess.PIPE)
    rustc.check_returncode()

    rustc_details = rustc.stdout.decode("utf8")
    host = re.search(r"host: (.*)", rustc_details)
    if host is None:
        raise ValueError("unexpected rustc output")
    return host.group(1)

def find_rust_lld():
    try:
        which = subprocess.run(["rustup", "which", "rustc"], stdout=subprocess.PIPE, stderr=subprocess.PIPE)
    except FileNotFoundError:
        return "lld"
    which.check_returncode()

    rustc_path = which.stdout.decode("utf8").strip()
    assert path.basename(rustc_path) == "rustc"

    bin_path = path.dirname(rustc_path)
    triplet = find_host_triplet()

    rust_lld_path = path.join(bin_path, "../lib/rustlib", triplet, "bin/rust-lld")
    assert path.isfile(rust_lld_path)

    return rust_lld_path

main()
